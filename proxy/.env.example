# Required: deployed clawpost worker base URL (no trailing /api)
CLAWPOST_UPSTREAM_URL=https://your-worker.workers.dev

# Required: API key for the deployed worker
CLAWPOST_UPSTREAM_API_KEY=replace_me

# Optional: bind host/port for local proxy
CLAWPOST_PROXY_HOST=127.0.0.1
CLAWPOST_PROXY_PORT=8788

# Optional: if set, local callers must send either:
# - Authorization: Bearer <token>
# - X-Proxy-Token: <token>
CLAWPOST_PROXY_AUTH_TOKEN=
